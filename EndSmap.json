{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Australian Threatened Species Locations",
  "width": 600,
  "height": 500,
  "projection": { "type": "albers",
  "center": [0, -27],
  "rotate": [-133, 0],
  "parallels": [-18, -36],
  "scale": 700},
  "params": [
    {
      "name": "statusFilter",
      "value": "Endangered",
      "bind": {
        "input": "select",
        "options": ["Endangered", "Vulnerable", "Critically Endangered", "Conservation Dependent"],
        "name": "EPBC Status: "
      }
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/JoshOrrMOnash/FIT2179A2/refs/heads/main/AusMap.json",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "mark": {"type": "geoshape", "fill": "lightgray", "stroke": "white"}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/JoshOrrMOnash/FIT2179A2/refs/heads/main/Aus%20animal%20populations%20over%20time.csv"
      },
      "transform": [
        {"filter": "datum.EPBCStatus == statusFilter"}
      ],
      "mark": {"type": "circle", "opacity": 0.4, "size": 30},
      "encoding": {
        "longitude": {"field": "RegionCentroidLongitude", "type": "quantitative"},
        "latitude": {"field": "RegionCentroidLatitude", "type": "quantitative"},
        "color": {"field": "TaxonomicGroup", "type": "nominal", "title": "Taxonomic Group"},
        "tooltip": [
          {"field": "CommonName", "title": "TaxonomicGroup"},
          {"field": "TaxonomicGroup", "title": "Class"},
          {"field": "EPBCStatus", "title": "EPBC Status"},
          {"field": "State", "title": "State"},
          {"field": "Region", "title": "Region"}
        ]
      }
    }
  ]
}